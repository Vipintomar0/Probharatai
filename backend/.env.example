# ProBharatAI Environment Configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-here

# LLM Provider (openai, claude, groq, gemini, ollama, openrouter)
DEFAULT_LLM_PROVIDER=openai

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Browser
BROWSER_HEADLESS=false
DEFAULT_BROWSER=chromium

# Security
REQUIRE_APPROVAL=true
MAX_ACTIONS_WITHOUT_APPROVAL=5

# Logging
LOG_LEVEL=INFO
